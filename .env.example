LOG_LEVEL=INFO

S3_BUCKET=my-models
S3_ENDPOINT=s3.example.com
S3_ACCESS_KEY=your-access-key
S3_SECRET_KEY=your-secret-key

HF_TOKEN=hf_<my-token>

OPENCODE_URL=http://localhost:54321
OPENCODE_PROVIDER=llamacpp

MLFLOW_TRACKING_URI=
MLFLOW_TRACKING_USERNAME=
MLFLOW_TRACKING_PASSWORD=
# Set to false to allow direct S3 uploads (requires AWS credentials)
