LOG_LEVEL=INFO

S3_BUCKET=my-models
S3_ENDPOINT=s3.example.com
S3_ACCESS_KEY=your-access-key
S3_SECRET_KEY=your-secret-key

HF_TOKEN=hf_<my-token>

